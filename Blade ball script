RunService.Heartbeat:Connect(function(dt)
    table.insert(fpsSamples, 1/dt)
    if #fpsSamples > 20 then table.remove(fpsSamples, 1) end
    fpsTimer += dt
    if fpsTimer >= 0.5 then
        fpsTimer = 0
        local sum = 0
        for _, v in ipairs(fpsSamples) do sum += v end
        local avg = math.floor(sum / #fpsSamples)
        FpsCountLbl.Text = "FPS الحالي:  " .. avg
        FpsCountLbl.TextColor3 = avg >= 45 and S.SuccessColor
            or avg >= 25 and S.WarnColor
            or S.DangerColor
    end
end)

