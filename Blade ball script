local function MakeTab(label, order)
    local Btn = Instance.new("TextButton")
    Btn.Text            = label
    Btn.Font            = Enum.Font.GothamBold
    Btn.TextSize        = 11
    Btn.TextColor3      = Color3.fromRGB(100,100,140)
    Btn.BackgroundColor3 = Color3.fromRGB(18,18,28)
    Btn.Size            = UDim2.new(0.33,-2,1,0)
    Btn.BorderSizePixel = 0
    Btn.LayoutOrder     = order
    Btn.ZIndex          = 7
    Btn.Parent          = TabContainer
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0,6)

    local Page = Instance.new("ScrollingFrame")
    Page.Size                = UDim2.new(1,0,1,0)
    Page.BackgroundTransparency = 1
    Page.BorderSizePixel     = 0
    Page.ScrollBarThickness  = 2
    Page.ScrollBarImageColor3 = AC
    Page.CanvasSize          = UDim2.new(0,0,0,0)
    Page.Visible             = false
    Page.ZIndex              = 6
    Page.Parent              = ContentArea

    local List = Instance.new("UIListLayout")
    List.SortOrder = Enum.SortOrder.LayoutOrder
    List.Padding   = UDim.new(0,7)
    List.Parent    = Page

    local Pad = Instance.new("UIPadding")
    Pad.PaddingTop    = UDim.new(0,4)
    Pad.PaddingBottom = UDim.new(0,4)
    Pad.Parent        = Page

    TabBtns[label] = Btn
    Pages[label]   = Page

    Btn.MouseButton1Click:Connect(function()
        if ActivePage == label then return end
        if ActivePage then
            Pages[ActivePage].Visible = false
            TweenService:Create(TabBtns[ActivePage], TweenInfo.new(0.15), {
                BackgroundColor3 = Color3.fromRGB(18,18,28),
                TextColor3       = Color3.fromRGB(100,100,140),
            }):Play()
        end
        ActivePage = label
        Page.Visible = true
        TweenService:Create(Btn, TweenInfo.new(0.15), {
            BackgroundColor3 = AC,
            TextColor3       = Color3.fromRGB(255,255,255),
        }):Play()
        -- تحديث حجم الكانفاس
        task.wait(0.05)
        local layout = Page:FindFirstChildOfClass("UIListLayout")
        if layout then
            Page.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 10)
        end
    end)

    return Page
end

