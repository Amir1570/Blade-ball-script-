-- ══════════════════════════════════════════════
--           AUTO PARRY LOGIC
-- ══════════════════════════════════════════════
local lastParry = 0
local function TryParry()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local now = tick()
    if now - lastParry < 0.3 then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and
            (obj.Name:lower():find("ball") or obj.Name:lower():find("blade")) then
            if (obj.Position - hrp.Position).Magnitude < 22 then
                lastParry = now
                task.wait(S.ParryDelay / 1000)
                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Parry", true)
                    or game:GetService("ReplicatedStorage"):FindFirstChild("ParryEvent", true)
                    or game:GetService("ReplicatedStorage"):FindFirstChild("RE", true)
                if remote and remote:IsA("RemoteEvent") then
                    remote:FireServer()
                    StatusLbl.Text = "الوضع: تم الصد ✅"
                    StatusDot.BackgroundColor3 = S.SuccessColor
                    AddLog("تم الصد! 🛡 المسافة: " ..
                        math.floor((obj.Position - hrp.Position).Magnitude), S.SuccessColor)
                end
                break
            end
        end
    end
end

-- ══════════════════════════════════════════════
--         RANDOM MOVEMENT LOGIC
-- ══════════════════════════════════════════════
local Dirs = {
    Vector3.new(1,0,0),  Vector3.new(-1,0,0),
    Vector3.new(0,0,1),  Vector3.new(0,0,-1),
    Vector3.new(1,0,1).Unit,  Vector3.new(-1,0,-1).Unit,
    Vector3.new(1,0,-1).Unit, Vector3.new(-1,0,1).Unit,
}
local lastMove = 0

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    if S.AutoParry then TryParry() end

    if S.RandomMovement then
        local now = tick()
        if now - lastMove >= S.MoveInterval / 1000 then
            lastMove = now
            local dir  = Dirs[math.random(1,#Dirs)]
            hum:MoveTo(hrp.Position + dir * S.MoveSpeed)
        end
    end
end)

