local function CreateToggle(page, labelText, descText, settingKey, onToggle)
    local Row = Instance.new("Frame")
    Row.Size             = UDim2.new(1,-0,0,68)
    Row.BackgroundColor3 = Color3.fromRGB(20,20,32)
    Row.BorderSizePixel  = 0
    Row.Parent           = page
    Instance.new("UICorner", Row).CornerRadius = UDim.new(0,12)

    local Lbl = Instance.new("TextLabel")
    Lbl.Text             = labelText
    Lbl.Font             = Enum.Font.GothamBold
    Lbl.TextSize         = 13
    Lbl.TextColor3       = Color3.fromRGB(230,230,255)
    Lbl.BackgroundTransparency = 1
    Lbl.Size             = UDim2.new(1,-70,0,22)
    Lbl.Position         = UDim2.new(0,14,0,12)
    Lbl.TextXAlignment   = Enum.TextXAlignment.Left
    Lbl.Parent           = Row

    local Desc = Instance.new("TextLabel")
    Desc.Text            = descText
    Desc.Font            = Enum.Font.Gotham
    Desc.TextSize        = 10
    Desc.TextColor3      = Color3.fromRGB(90,90,120)
    Desc.BackgroundTransparency = 1
    Desc.Size            = UDim2.new(1,-70,0,16)
    Desc.Position        = UDim2.new(0,14,0,36)
    Desc.TextXAlignment  = Enum.TextXAlignment.Left
    Desc.Parent          = Row

    local TrackOff = Color3.fromRGB(38,38,55)
    local Track = Instance.new("Frame")
    Track.Size            = UDim2.new(0,46,0,26)
    Track.Position        = UDim2.new(1,-58,0.5,-13)
    Track.BackgroundColor3 = S[settingKey] and S.AccentColor or TrackOff
    Track.BorderSizePixel = 0
    Track.Parent          = Row
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1,0)

    local Thumb = Instance.new("Frame")
    Thumb.Size            = UDim2.new(0,20,0,20)
    Thumb.Position        = S[settingKey]
        and UDim2.new(0,23,0.5,-10)
        or  UDim2.new(0,3, 0.5,-10)
    Thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
    Thumb.BorderSizePixel  = 0
    Thumb.Parent           = Track
    Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1,0)

    local ti = TweenInfo.new(0.18, Enum.EasingStyle.Quad)
    Track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
            S[settingKey] = not S[settingKey]
            local on = S[settingKey]
            TweenService:Create(Track, ti, {BackgroundColor3 = on and S.AccentColor or TrackOff}):Play()
            TweenService:Create(Thumb, ti, {
                Position = on and UDim2.new(0,23,0.5,-10) or UDim2.new(0,3,0.5,-10)
            }):Play()
            if onToggle then onToggle(on) end
        end
    end)
end

