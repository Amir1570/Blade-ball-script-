--              LOG SYSTEM
-- ══════════════════════════════════════════════
local LogEntries = {}
local MAX_LOG    = 50
local LogFrame   -- defined later

local function AddLog(msg, color)
    local entry = {
        text  = os.date("%H:%M:%S") .. "  " .. msg,
        color = color or Color3.fromRGB(200, 200, 220),
    }
    table.insert(LogEntries, 1, entry)
    if #LogEntries > MAX_LOG then table.remove(LogEntries) end

    -- rebuild log UI if visible
    if LogFrame then
        for _, child in ipairs(LogFrame:GetChildren()) do
            if child:IsA("TextLabel") then child:Destroy() end
        end
        for i, e in ipairs(LogEntries) do
            local lbl = Instance.new("TextLabel")
            lbl.Text              = e.text
            lbl.Font              = Enum.Font.Code
            lbl.TextSize          = 11
            lbl.TextColor3        = e.color
            lbl.BackgroundTransparency = 1
            lbl.Size              = UDim2.new(1, -8, 0, 16)
            lbl.Position          = UDim2.new(0, 4, 0, (i-1)*17)
            lbl.TextXAlignment    = Enum.TextXAlignment.Left
            lbl.TextTruncate      = Enum.TextTruncate.AtEnd
            lbl.Parent            = LogFrame
        end
        LogFrame.CanvasSize = UDim2.new(0, 0, 0, #LogEntries * 17)
    end
end

