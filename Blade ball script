-- ══════════════════════════════════════════════
do
    local drag, dragIn, startP, startM
    TitleBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag   = true
            startP = i.Position
            startM = Main.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag = false end
            end)
        end
    end)
    TitleBar.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement then dragIn = i end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i == dragIn then
            local d = i.Position - startP
            Main.Position = UDim2.new(
                startM.X.Scale, startM.X.Offset + d.X,
                startM.Y.Scale, startM.Y.Offset + d.Y
            )
        end
    end)
end

