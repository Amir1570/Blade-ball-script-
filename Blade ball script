                    v.Transparency = 0
                end
            end)
        end
        Log("وضع FPS: مغلق", SC)
    end
end)

-- عداد FPS
local fpsT, fpsS = 0, {}
RunService.Heartbeat:Connect(function(dt)
    table.insert(fpsS, 1/dt)
    if #fpsS > 30 then table.remove(fpsS,1) end
    fpsT += dt
    if fpsT >= 0.5 then
        fpsT = 0
        local s = 0
        for _, v in ipairs(fpsS) do s += v end
        local avg = math.floor(s/#fpsS)
        fpsLbl.Text       = "FPS:  " .. avg
        fpsLbl.TextColor3 = avg >= 45 and SC or avg >= 25 and WC or DC
    end
end)

