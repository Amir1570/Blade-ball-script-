-- ══════════════════════════════════════════════
--           منطق Auto Parry
-- ══════════════════════════════════════════════
local lastParry = 0

local function TryParry()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if tick() - lastParry < 0.25 then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local n = obj.Name:lower()
            if n:find("ball") or n:find("blade") or n:find("orb") then
                if (obj.Position - hrp.Position).Magnitude < 25 then
                    lastParry = tick()
                    task.wait(S.ParryDelay / 100)
                    -- البحث عن الـ RemoteEvent
                    local rem = ReplicatedStorage:FindFirstChild("Parry", true)
                        or ReplicatedStorage:FindFirstChild("ParryEvent", true)
                        or ReplicatedStorage:FindFirstChild("RE", true)
                        or ReplicatedStorage:FindFirstChild("Remote", true)
                    if rem and rem:IsA("RemoteEvent") then
                        pcall(function() rem:FireServer() end)
                        SetStatus("تم الصد! ✅", SC)
                        Log("صد ناجح 🛡", SC)
                    end
                    break
                end
            end
        end
    end
end

-- ══════════════════════════════════════════════
--          منطق الحركة العشوائية
-- ══════════════════════════════════════════════
local Dirs = {
    Vector3.new(1,0,0), Vector3.new(-1,0,0),
    Vector3.new(0,0,1), Vector3.new(0,0,-1),
    Vector3.new(1,0,1).Unit, Vector3.new(-1,0,-1).Unit,
    Vector3.new(1,0,-1).Unit, Vector3.new(-1,0,1).Unit,
}
local lastMove = 0

RunService.Heartbeat:Connect(function()
    local ok, char = pcall(function() return LocalPlayer.Character end)
    if not ok or not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    if S.AutoParry then
        pcall(TryParry)
    end

    if S.RandomMovement then
        local now = tick()
        if now - lastMove >= (1 / math.max(S.MoveInterval, 1)) then
            lastMove = now
            local dir = Dirs[math.random(1,#Dirs)]
            pcall(function() hum:MoveTo(hrp.Position + dir * 18) end)
        end
    end
end)

