--              LOG
-- ══════════════════════════════════════════════
local LogList  = {}
local LogInner -- defined below

local function Log(msg, color)
    table.insert(LogList, 1, {t = os.date("%H:%M:%S"), m = msg, c = color or Color3.fromRGB(190,190,220)})
    if #LogList > 60 then table.remove(LogList) end
    if not LogInner then return end
    for _, ch in ipairs(LogInner:GetChildren()) do
        if ch:IsA("TextLabel") then ch:Destroy() end
    end
    for i, e in ipairs(LogList) do
        local lb = Instance.new("TextLabel")
        lb.Text             = e.t .. "  " .. e.m
        lb.Font             = Enum.Font.Code
        lb.TextSize         = 10
        lb.TextColor3       = e.c
        lb.BackgroundTransparency = 1
        lb.Size             = UDim2.new(1,-6,0,15)
        lb.Position         = UDim2.new(0,3,0,(i-1)*16)
        lb.TextXAlignment   = Enum.TextXAlignment.Left
        lb.TextTruncate     = Enum.TextTruncate.AtEnd
        lb.ZIndex           = 9
        lb.Parent           = LogInner
    end
    LogInner.CanvasSize = UDim2.new(0,0,0,#LogList*16+4)
end

